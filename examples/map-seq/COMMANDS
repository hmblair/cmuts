#!/bin/bash

# Run from the directory containing this script, so the cleanup below and the
# relative paths are scoped here regardless of the caller's working directory.
cd "$(dirname "$0")" || exit 1

rm -rf *.log *.cmfa outputs

mkdir outputs
cd outputs

THREADS=8
ALIGNMENTS="alignments"
COUNTS="counts.h5"
PROFILES="profiles.h5"

FASTQ="../fastq"
FASTA="../ref.fasta"

cmuts align \
  --fasta "$FASTA" \
  --threads "$THREADS" \
  --output "$ALIGNMENTS" \
  "$FASTQ"/*.fastq*

cmuts core \
  -f "$FASTA" \
  -o "$COUNTS" \
  --no-insertions \
  "$ALIGNMENTS"/*

cmuts normalize "$COUNTS" \
  -o "$PROFILES" \
  --fasta "$FASTA" \
  --experiment 2A3 mod="$ALIGNMENTS/bicine-2A3" nomod="$ALIGNMENTS/bicine-DMSO" \
  --experiment DMS mod="$ALIGNMENTS/bicine-DMS" nomod="$ALIGNMENTS/bicine-ETH" \
  --per-experiment-norm

cd ..
