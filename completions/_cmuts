#compdef cmuts
# Generated by scripts/generate_completions.py — do not edit manually

_cmuts() {
    local -a subcommands
    subcommands=(
        'align:Align FASTQ files to a reference'
        'core:Count chemical mutations from aligned reads'
        'generate:Generate synthetic test data'
        'normalize:Normalize mutation counts to reactivity profiles'
        'plot:Plot reactivity profiles'
        'visualize:Color 3D structures by reactivity'
        'test:Run integration tests'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--log[Log file]: :_files' \
        '1:subcommand:->subcmd' \
        '*::arg:->args'

    case "$state" in
        subcmd)
            _describe 'subcommand' subcommands
            ;;
        args)
            case "$words[1]" in
                core)
                    _arguments \
                        '(-o --output)-o[The output HDF5 file.]: :' \
                        '(-o --output)--output[The output HDF5 file.]: :' \
                        '(-f --fasta)-f[The reference FASTA file.]: :' \
                        '(-f --fasta)--fasta[The reference FASTA file.]: :' \
                        '--overwrite[Overwrite an existing HDF5 file.]' \
                        '--rebuild[Rebuild all index files.]' \
                        '(-c --compression)-c[Compression level of the HDF5 output (0-9).]: :' \
                        '(-c --compression)--compression[Compression level of the HDF5 output (0-9).]: :' \
                        '--print-every[How often (in seconds) to print statistics.]: :' \
                        '(-v --verbose)-v[Enable verbose (debug) logging to .cmuts.log file.]' \
                        '(-v --verbose)--verbose[Enable verbose (debug) logging to .cmuts.log file.]' \
                        '--pairwise[Compute pairwise modification counts.]' \
                        '--tokenize[Tokenize the reference sequences.]' \
                        '--min-mapq[Mapping quality threshold for alignment processing.]: :' \
                        '--min-phred[PHRED score threshold for base processing.]: :' \
                        '--min-length[Skip reads shorter than this length.]: :' \
                        '--max-length[Skip reads longer than this length.]: :' \
                        '--max-hamming[The maximum number of mismatches, insertions, and deletions in a processed read.]: :' \
                        '--secondary[Consider secondary alignments for processing as well.]' \
                        '--downsample[Limit read depths per reference.]: :' \
                        '--ignore-bases[Do not count mismatches or deletions occurring at these bases. Pass as a single string.]: :' \
                        '--max-indel-length[The longest indels to consider.]: :' \
                        '--quality-window[Check the quality of each base in a window of this size around each base.]: :' \
                        '--collapse[Collapse modifications within this distance of each other in a given read.]: :' \
                        '--chunk-size[The number of references to process at a time per thread.]: :' \
                        '--no-mismatches[Do not count mismatches as modifications.]' \
                        '--no-insertions[Do not count insertions as modifications.]' \
                        '--no-deletions[Do not count deletions as modifications.]' \
                        '--no-reverse[Ignore reverse-complemented reads.]' \
                        '--only-reverse[Use only reverse-complemented reads.]' \
                        '--uniform-spread[Uniformly spread out ambiguous deletions.]' \
                        '--no-spread[Do not spread ambiguous deletions.]' \
                        '--disable-ambiguous[Disable the ambiguous deletion detection algorithm, relying on the deletion provided by the alignment.]' \
                        '--no-match-filter[Do not filter matches based on their PHRED base score.]' \
                        '--no-insertion-filter[Do not filter insertions based on their PHRED base score.]' \
                        '--no-deletion-filter[Do not filter deletions based on their PHRED base score.]' \
                        '--threads[Number of MPI processes]: :' \
                        '*:input files:_files -g "*.{sam,bam,cram}"'
                    ;;
                align)
                    _arguments \
                        '--fasta[Reference FASTA file]: :_files -g "*.{fa,fasta,fna}"' \
                        '--output[Output directory]: :_files -/' \
                        '--overwrite[Overwrite existing output]' \
                        '--rebuild[Rebuild index files]' \
                        '--verbose[Enable verbose output]' \
                        '--threads[Number of threads]: :' \
                        '--barcodes[Barcode file for demultiplexing]: :_files' \
                        "--trim-5[5' adapter sequence]: :" \
                        "--trim-3[3' adapter sequence]: :" \
                        '--local[Use local alignment mode]' \
                        '--pairs[Paired-end read files]: :_files -g "*.{fastq,fastq.gz,fq,fq.gz}"' \
                        '*:input files:_files -g "*.{fastq,fastq.gz,fq,fq.gz,bam}"'
                    ;;
                generate)
                    _arguments \
                        '--length[The length of the reference sequences.]: :' \
                        '--queries[The number of queries to generate per reference.]: :' \
                        '--references[The number of references to generate.]: :' \
                        '--seed[Random seed for reproducibility. If not provided, uses time-based seed.]: :' \
                        '--out-fasta[The file to store the references in.]: :' \
                        '(-o --out)-o[The output file for alignments (SAM, BAM, or CRAM).]: :' \
                        '(-o --out)--out[The output file for alignments (SAM, BAM, or CRAM).]: :' \
                        '--out-h5[The file to store the expected modifications in.]: :' \
                        '--min-mapq[The minimum quality to consider a read.]: :' \
                        '--min-phred[The minimum quality to consider a base.]: :' \
                        '--min-length[The smallest query sequences to consider when counting modifications.]: :' \
                        '--max-length[The longest query sequences to consider when counting modifications.]: :' \
                        '--max-indel-length[Skip indels longer than this.]: :' \
                        '--collapse[The minimum number of bases between modifications to consider them consecutive.]: :' \
                        '--quality-window[The number of neighbouring bases to consider when calculating PHRED scores.]: :' \
                        '--no-mismatches[Do not count mismatches as modifications.]' \
                        '--no-insertions[Do not count insertions as modifications.]' \
                        '--no-deletions[Do not count deletions as modifications.]'
                    ;;
                normalize)
                    _arguments \
                        '--mod[Modified sample dataset names]: :' \
                        '--nomod[Non-modified sample dataset names]: :' \
                        '--fasta[Reference FASTA file]: :_files -g "*.{fa,fasta,fna}"' \
                        '--group[Output group name]: :' \
                        '(-o --out)'{-o,--out}'[Output HDF5 file]: :_files -g "*.h5"' \
                        '--overwrite[Overwrite existing file]' \
                        '--clip-low[Clip negative reactivity values]' \
                        '--clip-high[Clip reactivity values above 1]' \
                        "--blank-5p[NaN out bases on 5' end]: :" \
                        "--blank-3p[NaN out bases on 3' end]: :" \
                        '--blank-cutoff[Min reads for position]: :' \
                        '--norm-independent[Normalize each profile separately]' \
                        '--norm[Normalization method]: :(ubr raw outlier)' \
                        '--norm-cutoff[Min reads for normalization]: :' \
                        '--norm-percentile[Normalization percentile]: :' \
                        '--no-insertions[Exclude insertions from reactivity]' \
                        '--no-deletions[Exclude deletions from reactivity]' \
                        '--sig[Significance level]: :' \
                        '*:input file:_files -g "*.h5"'
                    ;;
                plot)
                    _arguments \
                        '--files[HDF5 input files]: :_files -g "*.h5"' \
                        '--datasets[Dataset names]: :' \
                        '--labels[Plot labels]: :' \
                        '--index[Dataset index]: :' \
                        "--trim-5p[Trim bases from 5' end]: :" \
                        "--trim-3p[Trim bases from 3' end]: :"
                    ;;
                visualize)
                    _arguments \
                        '--file[HDF5 input file]: :_files -g "*.h5"' \
                        '--dataset[Dataset name]: :' \
                        '--cif[CIF structure file]: :_files -g "*.{cif,mmcif}"' \
                        '--fasta[Reference FASTA file]: :_files -g "*.{fa,fasta,fna}"' \
                        '--bin[ChimeraX binary path]: :_files' \
                        '--index[Dataset index]: :' \
                        '--chain[Structure chain]: :' \
                        '--color[ChimeraX color name]: :' \
                        "--trim-5p[Trim bases from 5' end]: :" \
                        "--trim-3p[Trim bases from 3' end]: :"
                    ;;
                test)
                    _arguments \
                        '--quick[Run quick tests only]' \
                        '--cram[Run CRAM-specific tests only]'
                    ;;
            esac
            ;;
    esac
}

_cmuts "$@"
